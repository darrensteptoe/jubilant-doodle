{
  "name": "field-app-40",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "package:runtime": "node scripts/package-runtime-bundle.mjs",
    "typecheck": "tsc --noEmit",
    "check:canonical-math": "node scripts/check-canonical-math.mjs",
    "check:interaction-integrity": "node scripts/interaction-integrity.mjs",
    "check:interaction-integrity:strict": "node scripts/interaction-integrity.mjs --strict",
    "check:interaction-pages": "node scripts/interaction-page-reports.mjs",
    "check:render-lifecycle-contract": "node --test js/app/v3/surfaces/district/renderLifecycle.contract.test.js",
    "check:contracts": "node scripts/check-contract-diagnostics.mjs",
    "check:golden-fixtures": "node --test js/core/state/goldenFullStateRegression.test.js",
    "check:complexity-guardrails": "node scripts/check-complexity-guardrails.mjs",
    "check:built-artifact": "node scripts/check-built-artifact.mjs",
    "check:hardening-surface-integrity": "node --test js/app/v3/surfaces/hardeningSurfaceIntegrity.contract.test.js js/app/v3/surfaces/data/reportingGuidance.contract.test.js js/app/v3/surfaces/turnout.contract.test.js",
    "gate:drift": "node scripts/gate-architectural-drift.mjs",
    "gate:rebuild": "node scripts/gate-rebuild.mjs",
    "gate:gauntlet": "node scripts/release-gauntlet.mjs",
    "gate:freeze": "node scripts/freeze-gate.mjs",
    "gate:release": "npm run gate:rebuild && node js/core/selfTestSuites/releaseHardening.js",
    "qa:new-parity-log": "node scripts/new-manual-parity-log.mjs",
    "status:rebuild": "node scripts/rebuild-status.mjs",
    "status:manual-parity": "node scripts/manual-parity-status.mjs",
    "gate:manual-parity": "node scripts/manual-parity-status.mjs --strict",
    "check:district-integrity": "node scripts/district-integrity.mjs",
    "debug:runtime-parity": "node scripts/runtime-parity-audit.mjs",
    "check:spacing-contract": "node --test js/app/v3/surfaces/spacingContract.test.js"
  },
  "devDependencies": {
    "typescript": "^5.9.2",
    "vite": "^7.1.4"
  }
}
